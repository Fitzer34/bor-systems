PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgres://bor:bor@localhost:5432/bor_systems

# Cloudflare R2 (persistent storage for floor-plan images on Render).
# Leave blank for local dev — uploads go to ./uploads/floorplans/ on disk.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=8h

# Shared secret used to verify uplinks from The Things Stack webhook integration
TTS_WEBHOOK_SECRET=change-me

# Resolution timer default in minutes (sign not returned -> rebroadcast + escalate)
RESOLUTION_TIMER_MINUTES=15

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# Twilio (SMS escalation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (SES or SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@bor-systems.local
