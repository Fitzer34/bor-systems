PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgres://bor:bor@localhost:5432/bor_systems

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=8h

# Shared secret used to verify uplinks from The Things Stack webhook integration
TTS_WEBHOOK_SECRET=change-me

# Resolution timer default in minutes (sign not returned -> rebroadcast + escalate)
RESOLUTION_TIMER_MINUTES=15

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# Twilio (SMS escalation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (SES or SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@bor-systems.local
