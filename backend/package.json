{
  "name": "@bor-systems/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrate.ts",
    "migrate:prod": "node dist/migrate.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:seed:demo": "tsx src/seed-demo.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@sentry/node": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "argon2": "^0.40.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "firebase-admin": "^12.4.0",
    "nodemailer": "^6.9.14",
    "otplib": "^12.0.1",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.4",
    "qrcode": "^1.5.4",
    "twilio": "^5.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
