default_platform(:ios)

# TestFlight deploy for the BORSystems iOS app.
#
# Prereqs (one-time):
#   1. An App Store Connect API key (App Store Connect → Users and Access →
#      Integrations → keys). Download the .p8 once.
#   2. An app record with bundle id com.borsystems.app.
#   3. `gem install fastlane` (or `bundle`).
#
# Run:
#   cd ios
#   ASC_KEY_ID=XXXX ASC_ISSUER_ID=xxxx-xxxx ASC_KEY_PATH=/abs/AuthKey_XXXX.p8 \
#     fastlane beta
#
# Signing is automatic: `-allowProvisioningUpdates` lets Xcode create the
# Apple Distribution cert + App Store provisioning profile via the API key,
# so no manual cert wrangling is required.
platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
    )

    # Bump the build number to the next TestFlight value so uploads never clash.
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key).to_i + 1,
      xcodeproj: "BORSystems.xcodeproj",
    )

    build_app(
      project: "BORSystems.xcodeproj",
      scheme: "BORSystems",
      export_method: "app-store",
      export_options: "ExportOptions.plist",
      xcargs: "-allowProvisioningUpdates",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
